{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Complaint": {
      "title": "Civic Complaint",
      "description": "A report submitted by a citizen",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "issueType": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Resolved"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "imageUrl": { "type": "string" },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "description", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Global collection of complaints"
    }
  }
}
